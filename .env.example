# Core runtime
NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# Security-sensitive secrets
# Required in production (safe local defaults shown here for development only)
JWT_SECRET=dev-local-secret
ADMIN_SEED_PASSWORD=change_me_admin_password
STRIPE_WEBHOOK_SECRET=

# Storage bootstrap
# DATA_STORE_MODE supports: memory | file
DATA_STORE_MODE=memory
DATA_STORE_FILE=.data/store.json

# Compliance / governance retention windows
SUPPORT_TICKET_RETENTION_DAYS=365
FRAUD_SIGNAL_RETENTION_DAYS=365
GOVERNANCE_REQUEST_RETENTION_DAYS=730
FRAUD_REPEATED_REFUND_THRESHOLD=3

# Backup / recovery planning hook
BACKUP_EXPORT_DIR=.data/backups
ANONYMIZED_EMAIL_DOMAIN=redacted.local
