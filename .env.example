# Core runtime
NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# Security-sensitive secrets
# Required in production (safe local defaults shown here for development only)
JWT_SECRET=dev-local-secret
ADMIN_SEED_PASSWORD=change_me_admin_password
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
KYC_PROVIDER=persona
KYC_PROVIDER_API_KEY=
KYC_PROVIDER_WEBHOOK_SECRET=
KYC_TEMPLATE_ID=
KYC_PROVIDER_BASE_URL=https://verify.drive.local

# Storage bootstrap
# DATA_STORE_MODE supports: memory | file
DATA_STORE_MODE=memory
DATA_STORE_FILE=.data/store.json

# ─── PostgreSQL database ─────────────────────────────────────────────────────
# When DATABASE_URL is set the server will run migrations on startup and the
# database layer will be available for Phase 2 migration of the data store.
# Leave blank (or unset) to keep running in the default in-memory mode.
#
# Local development (requires docker-compose postgres service):
# DATABASE_URL=******localhost:5432/drive_local
#
# Production example (replace with real credentials):
# DATABASE_URL=******prod.rds.amazonaws.com:5432/drive_prod
DATABASE_URL=

# Maximum number of PostgreSQL pool connections (optional, default: 10)
# DATABASE_POOL_MAX=10

# Background jobs
REDIS_URL=redis://localhost:6379

# SendGrid (email)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@drive.app
SENDGRID_FROM_NAME=Drive App

# Twilio (sms)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1234567890

# Mapbox public token – used by the driver dashboard for Mapbox Directions API
# This is a public (pk.*) token and is safe to set here; override in production if needed.
MAPBOX_PUBLIC_TOKEN=pk.eyJ1IjoiZmx1cGZsYXAiLCJhIjoiY21wMjI3M3dpMDN5eTJycHMyeG8yaDZ3OCJ9.VUXlzIoU5Gxfj6-BVjnxag

# ─── SendGrid (email) ─────────────────────────────────────────────────────────
# Sign up at https://sendgrid.com – create an API key with "Mail Send" access.
# When set, transactional emails (receipts, confirmations, etc.) are sent via SendGrid.
# When unset, emails are logged as stubs without actually sending.
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@drive.app

# ─── Twilio (SMS) ─────────────────────────────────────────────────────────────
# Sign up at https://twilio.com – get Account SID, Auth Token, and a phone number.
# When set, SMS alerts are sent via Twilio.
# When unset, SMS messages are logged as stubs without actually sending.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1234567890

# ─── App base URL ─────────────────────────────────────────────────────────────
# Used for generating deep-links in emails and SMS messages.
APP_BASE_URL=https://app.drive.com

# ─── Firebase Cloud Messaging (push notifications) ────────────────────────────
# Legacy server key for FCM push notifications.
# When unset, push notifications are logged as stubs.
FCM_SERVER_KEY=
