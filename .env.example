# Core runtime
NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# Security-sensitive secrets
# Required in production (safe local defaults shown here for development only)
JWT_SECRET=dev-local-secret
ADMIN_SEED_PASSWORD=Test123!Drive
TEST_RIDER_SEED_PASSWORD="Test123!Drive"
TEST_DRIVER_SEED_PASSWORD="Test123!Drive"

# ─── Stripe Payment Processing ──────────────────────────────────────────────────
# Sign up for a Stripe account at https://stripe.com
# Get your API keys from https://dashboard.stripe.com/apikeys
# 
# STRIPE_SECRET_KEY: Used on backend only (keep secret, never expose to frontend)
# STRIPE_PUBLISHABLE_KEY: Safe to expose in frontend (used by Stripe.js)
# STRIPE_WEBHOOK_SECRET: Used to verify webhook signatures from Stripe
#
# Test keys start with 'sk_test_' (secret) and 'pk_test_' (publishable)
# Live keys start with 'sk_live_' (secret) and 'pk_live_' (publishable)
STRIPE_SECRET_KEY=sk_test_51234567890abcdefghijklmnopqrstuvwxyz
STRIPE_PUBLISHABLE_KEY=pk_test_51234567890abcdefghijklmnopqrstuvwxyz
STRIPE_WEBHOOK_SECRET=whsec_test_1234567890abcdefghijklmnopqrstuvwxyz

FCM_SERVER_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
KYC_PROVIDER=persona
KYC_PROVIDER_API_KEY=
KYC_PROVIDER_WEBHOOK_SECRET=
KYC_TEMPLATE_ID=
KYC_PROVIDER_BASE_URL=https://verify.drive.local

# Storage bootstrap
# DATA_STORE_MODE supports: memory | file
DATA_STORE_MODE=file
DATA_STORE_FILE=.data/store.json

# CORS origins allowed to send credentialed browser requests
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# ─── PostgreSQL database ─────────────────────────────────────────────────────
# When DATABASE_URL is set the server will run migrations on startup and the
# database layer will be available for Phase 2 migration of the data store.
# Leave blank (or unset) to keep running in the default in-memory mode.
#
# Local development (requires docker-compose postgres service):
# DATABASE_URL=postgres://user:pass@localhost:5432/drive_local
#
# Production example (replace with real credentials):
# DATABASE_URL=postgres://user:pass@prod.rds.amazonaws.com:5432/drive_prod
DATABASE_URL=

# Maximum number of PostgreSQL pool connections (optional, default: 10)
# DATABASE_POOL_MAX=10

# Background jobs
REDIS_URL=redis://localhost:6379

# SendGrid (email)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@drive.app
SENDGRID_FROM_NAME=Drive App

# Twilio (sms)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1234567890

# Mapbox public token – used by the driver dashboard for Mapbox Directions API
# This is a public (pk.*) token and is safe to set here; override in production if needed.
MAPBOX_PUBLIC_TOKEN=pk.eyJ1IjoiZmx1cGZsYXAiLCJhIjoiY21wMjI3M3dpMDN5eTJycHMyeG8yaDZ3OCJ9.VUXlzIoU5Gxfj6-BVjnxag

# ─── App base URL ─────────────────────────────────────────────────────────
# Used for generating deep-links in emails and SMS messages.
APP_BASE_URL=https://app.drive.com

# ─── Firebase Cloud Messaging (push notifications) ────────────────────────────
# Legacy server key for FCM push notifications.
# When unset, push notifications are logged as stubs.
FCM_SERVER_KEY=
