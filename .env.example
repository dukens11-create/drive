# Core runtime
NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# Security-sensitive secrets
# Required in production (safe local defaults shown here for development only)
JWT_SECRET=dev-local-secret
ADMIN_SEED_PASSWORD=change_me_admin_password
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Storage bootstrap
# DATA_STORE_MODE supports: memory | file
DATA_STORE_MODE=memory
DATA_STORE_FILE=.data/store.json

# ─── PostgreSQL database ─────────────────────────────────────────────────────
# When DATABASE_URL is set the server will run migrations on startup and the
# database layer will be available for Phase 2 migration of the data store.
# Leave blank (or unset) to keep running in the default in-memory mode.
#
# Local development (requires docker-compose postgres service):
# DATABASE_URL=******localhost:5432/drive_local
#
# Production example (replace with real credentials):
# DATABASE_URL=******prod.rds.amazonaws.com:5432/drive_prod
DATABASE_URL=

# Maximum number of PostgreSQL pool connections (optional, default: 10)
# DATABASE_POOL_MAX=10

# Background jobs
REDIS_URL=redis://localhost:6379

# Mapbox public token – used by the driver dashboard for Mapbox Directions API
# This is a public (pk.*) token and is safe to set here; override in production if needed.
MAPBOX_PUBLIC_TOKEN=pk.eyJ1IjoiZmx1cGZsYXAiLCJhIjoiY21wMjI3M3dpMDN5eTJycHMyeG8yaDZ3OCJ9.VUXlzIoU5Gxfj6-BVjnxag
