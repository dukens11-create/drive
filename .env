# Development environment
NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# Auth and seed users
JWT_SECRET=dev-local-secret
ADMIN_SEED_PASSWORD=FlupflapHaiti2025@
TEST_RIDER_SEED_PASSWORD="Test123!@#$"
TEST_DRIVER_SEED_PASSWORD="Driver123!@#$"

# Persistent local datastore
DATA_STORE_MODE=file
DATA_STORE_FILE=.data/store.json

# CORS for local web portals with credentials
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Optional integrations (left blank in local dev)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
DATABASE_URL=
REDIS_URL=redis://localhost:6379
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@drive.app
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1234567890
APP_BASE_URL=http://localhost:8080
