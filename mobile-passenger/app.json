{
  "expo": {
    "name": "Drive Passenger",
    "slug": "drive-passenger",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "drivepassenger",
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "isAndroidBackgroundLocationEnabled": true,
          "isIosBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "sounds": [
            "./assets/sounds/incoming-request.wav"
          ]
        }
      ],
      "expo-av",
      "expo-font",
      "expo-secure-store"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dukens11.drivepassenger",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Drive Home needs your location to track live trips and nearby riders.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Drive Home uses your location in the background so trip updates stay responsive while you are online.",
        "UIBackgroundModes": [
          "location",
          "location"
        ]
      }
    },
    "android": {
      "package": "com.dukens11.drivepassenger",
      "permissions": [
        "POST_NOTIFICATIONS",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "POST_NOTIFICATIONS",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "config": {
        "googleMaps": {
          "apiKey": ""
        }
      }
    },
    "extra": {
      "apiBaseUrl": "http://localhost:3000",
      "emergencyNumber": "911",
      "mapboxToken": "pk.eyJ1IjoiZmx1cGZsYXAiLCJhIjoiY21wMjI3M3dpMDN5eTJycHMyeG8yaDZ3OCJ9.VUXlzIoU5Gxfj6-BVjnxag",
      "firebase": {
        "apiKey": "",
        "authDomain": "",
        "projectId": "",
        "databaseURL": "",
        "storageBucket": "",
        "messagingSenderId": "",
        "appId": ""
      },
      "router": {},
      "eas": {
        "projectId": "ee6137f2-0c85-4de2-a160-a224767ec98d"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/ee6137f2-0c85-4de2-a160-a224767ec98d"
    }
  }
}
